{
  "mcpServers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${env:GITHUB_PAT_FABRIC}",
        "X-MCP-Toolsets": "context,repos,issues,pull_requests,users,projects,discussions"
      }
    },
    "render": {
      "url": "https://mcp.render.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:RENDER_API_KEY}"
      }
    }
  }
}
