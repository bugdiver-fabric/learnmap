# GitHub Personal Access Token for the GitHub MCP server in Cursor.
# Create one at https://github.com/settings/tokens
# Required scopes: repo (private repos), read:org (org repos)
#
# Or reuse your gh CLI session token:
#   export GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=ghp_your_token_here

# --- Learnmap API (api/) ---

# HTTP port for the NestJS API
PORT=3000

# PostgreSQL — align with docker-compose.yml (#11)
DATABASE_URL=postgresql://learnmap:learnmap@localhost:5432/learnmap

NODE_ENV=development

# Render production — allowed CORS origin for the static app (set automatically via render.yaml fromService)
# APP_ORIGIN=https://learnmap-app.onrender.com

# Docker Compose only — run prisma db seed after migrations when api container starts (requires prisma.seed in api/package.json)
# SEED_DATABASE=true

# --- Learnmap app (app/) ---

# Vite dev proxy target for /api (default http://localhost:3000; docker compose sets http://api:3000)
# VITE_API_PROXY_TARGET=http://localhost:3000
